# ========================================
# Vibe Video Backend - Environment Variables
# 복사해서 .env로 사용. 절대 git에 커밋하지 말 것.
# ========================================

# --- Auth (단일 사용자, 하드코딩 비밀번호) ---
AUTH_PASSWORD=731331
SESSION_SECRET=change-this-to-random-string-min-32-chars

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibe_video

# --- LLM API Keys ---
# Gemini: https://aistudio.google.com/app/apikey (무료 티어 사용)
GEMINI_API_KEY=
# Claude: 후킹 멘트 생성 한정 사용 (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# --- 모델 지정 (변경하지 않는 것 권장) ---
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
CLAUDE_MODEL=claude-sonnet-4-6

# --- Storage (OneDrive 네트워크 폴더) ---
# 예: C:/Users/dolse/OneDrive/VibeVideo
# 또는: //ONEDRIVE-PC/VibeVideo
STORAGE_BASE_PATH=

# --- FFmpeg ---
# Windows에서 PATH에 없으면 절대 경로 지정 (예: C:/ffmpeg/bin/ffmpeg.exe)
FFMPEG_PATH=
FFPROBE_PATH=

# --- Server ---
PORT=3001
NODE_ENV=development
