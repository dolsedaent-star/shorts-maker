// ========================================================================
// Vibe Video - Prisma Schema
// ERD 7개 엔티티 + enum + 인덱스 정의
// ========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────

enum Tone {
  HUMOR
  SERIOUS
  EMOTIONAL
  INFORMATIVE
}

enum VideoStatus {
  DRAFT
  SCENARIOS_READY
  SECTIONS_READY
  TRIMMING
  AWAITING_ASSETS
  RENDERING
  DONE
  FAILED
}

enum ScenarioAngle {
  PROBLEM_SOLUTION
  DEMO
  BEFORE_AFTER
  TESTIMONIAL
  CURIOSITY_HOOK
}

enum LLMProvider {
  GEMINI_PRO
  GEMINI_FLASH
  CLAUDE_SONNET
  MANUAL_EDIT
}

enum TrimField {
  SCRIPT_TEXT
  VIDEO_PROMPT
}

enum RenderJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

enum StickerPosition {
  TOP_LEFT
  TOP_CENTER
  TOP_RIGHT
  MIDDLE_LEFT
  CENTER
  MIDDLE_RIGHT
  BOTTOM_LEFT
  BOTTOM_CENTER
  BOTTOM_RIGHT
}

enum StickerScale {
  SMALL
  MEDIUM
  LARGE
}

// ─── Models ─────────────────────────────────────────────────────────────

/// 앱 1개의 마케팅 캠페인 컨테이너
model Project {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  description       String   @db.Text
  appName           String   @map("app_name")
  targetUser        String   @map("target_user") @db.Text
  valueProposition  String   @map("value_proposition") @db.Text
  storeUrl          String?  @map("store_url")
  tone              Tone
  defaultDurationS  Int      @default(18) @map("default_duration_s")
  // Pretendard ExtraBold 등 자막 스타일 jsonb. 구조는 lib/subtitleStyle.ts 참고
  subtitleStyle     Json     @map("subtitle_style") @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  videos Video[]

  @@map("projects")
}

/// 쇼츠 1편 (한 프로젝트 내 variant)
model Video {
  id                    String      @id @default(uuid()) @db.Uuid
  projectId             String      @map("project_id") @db.Uuid
  title                 String
  durationSeconds       Int         @map("duration_seconds")
  status                VideoStatus @default(DRAFT)
  selectedScenarioId    String?     @map("selected_scenario_id") @db.Uuid
  subtitleStyleOverride Json?       @map("subtitle_style_override") @db.JsonB
  thumbnailPath         String?     @map("thumbnail_path")
  /// 사용자가 업로드한 배경음악 파일 경로. 렌더링 시 다이얼로그 위에 깔리고 마지막 1.5초 페이드아웃.
  bgmPath               String?     @map("bgm_path")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  selectedScenario Scenario?        @relation("VideoSelected", fields: [selectedScenarioId], references: [id], onDelete: SetNull)
  scenarios        Scenario[]       @relation("VideoAllScenarios")
  sections         Section[]
  renderJobs       RenderJob[]
  renderArtifacts  RenderArtifact[]
  stickers         Sticker[]

  @@index([projectId])
  @@index([status])
  @@map("videos")
}

/// 사용자가 영상 위에 얹는 PNG 스티커
model Sticker {
  id           String          @id @default(uuid()) @db.Uuid
  videoId      String          @map("video_id") @db.Uuid
  imagePath    String          @map("image_path")
  originalName String          @map("original_name")
  position     StickerPosition @default(BOTTOM_CENTER)
  scale        StickerScale    @default(MEDIUM)
  startSec     Float           @map("start_sec")
  endSec       Float           @map("end_sec")
  createdAt    DateTime        @default(now()) @map("created_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@map("stickers")
}

/// AI 제안 시나리오 후보 (Video당 2-3개)
model Scenario {
  id          String        @id @default(uuid()) @db.Uuid
  videoId     String        @map("video_id") @db.Uuid
  angle       ScenarioAngle
  content     String        @db.Text
  hookLine    String        @map("hook_line") @db.Text
  generatedBy LLMProvider   @map("generated_by")
  createdAt   DateTime      @default(now()) @map("created_at")

  video           Video   @relation("VideoAllScenarios", fields: [videoId], references: [id], onDelete: Cascade)
  selectedByVideo Video[] @relation("VideoSelected")

  @@index([videoId])
  @@map("scenarios")
}

/// 영상 조각 1개 (Video당 3-4개)
model Section {
  id                 String   @id @default(uuid()) @db.Uuid
  videoId            String   @map("video_id") @db.Uuid
  orderIndex         Int      @map("order_index")
  durationSeconds    Int      @map("duration_seconds")
  /// 콘티 이미지 생성용 프롬프트 (외부 이미지 도구용, 영문)
  imagePrompt        String?  @map("image_prompt") @db.Text
  /// 사용자가 외부에서 만들어 업로드한 콘티 이미지 (image-to-video 참조용)
  sourceImagePath    String?  @map("source_image_path")
  /// 영상 생성 프롬프트 (외부 image-to-video 도구용, 영문)
  videoPrompt        String   @map("video_prompt") @db.Text
  /// 화면 자막 = TTS 대본 통합 텍스트
  scriptText         String   @map("script_text") @db.Text
  sourceVideoPath    String?  @map("source_video_path")
  sourceAudioPath    String?  @map("source_audio_path")
  /// scale=1080:1920 블러 패딩 정규화 결과 캐시 경로
  processedVideoPath String?  @map("processed_video_path")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  video       Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  trimHistory TrimHistory[]

  @@unique([videoId, orderIndex])
  @@map("sections")
}

/// Trim 루프 편집 이력
model TrimHistory {
  id              String      @id @default(uuid()) @db.Uuid
  sectionId       String      @map("section_id") @db.Uuid
  field           TrimField
  beforeText      String      @map("before_text") @db.Text
  afterText       String      @map("after_text") @db.Text
  userInstruction String?     @map("user_instruction") @db.Text
  llmUsed         LLMProvider @map("llm_used")
  createdAt       DateTime    @default(now()) @map("created_at")

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("trim_history")
}

/// 렌더링 작업 상태 (UI 진행률용, pg-boss 작업과 1:1)
model RenderJob {
  id           String          @id @default(uuid()) @db.Uuid
  videoId      String          @map("video_id") @db.Uuid
  pgBossJobId  String          @map("pg_boss_job_id")
  status       RenderJobStatus @default(QUEUED)
  progressPct  Int             @default(0) @map("progress_pct")
  currentStep  String?         @map("current_step")
  errorMessage String?         @map("error_message") @db.Text
  startedAt    DateTime?       @map("started_at")
  finishedAt   DateTime?       @map("finished_at")
  createdAt    DateTime        @default(now()) @map("created_at")

  video     Video            @relation(fields: [videoId], references: [id], onDelete: Cascade)
  artifacts RenderArtifact[]

  @@index([videoId])
  @@index([status])
  @@map("render_jobs")
}

/// 렌더링 결과 (재렌더마다 version 누적, 덮어쓰지 않음)
model RenderArtifact {
  id                    String   @id @default(uuid()) @db.Uuid
  videoId               String   @map("video_id") @db.Uuid
  version               Int
  filePath              String   @map("file_path")
  fileSizeBytes         BigInt   @map("file_size_bytes")
  durationActualSeconds Float    @map("duration_actual_seconds")
  renderJobId           String   @map("render_job_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")

  video     Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  renderJob RenderJob @relation(fields: [renderJobId], references: [id])

  @@unique([videoId, version])
  @@index([videoId])
  @@map("render_artifacts")
}
